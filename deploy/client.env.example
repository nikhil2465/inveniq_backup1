# ============================================================================
# InvenIQ v3.0 — Client Deployment Configuration
# Copy this file to: backend/.env and fill in the values below.
#
# TWO ACCOUNT SYSTEM:
#   AUTH_USERNAME/AUTH_PASSWORD  — client-facing login (restricted modules)
#   OWNER_USERNAME/OWNER_PASSWORD — developer/admin backdoor (full access, always)
#
# Set AUTH_ROLE=client and AUTH_ALLOWED_MODULES to restrict what the client sees.
# Set AUTH_ROLE=admin and AUTH_ALLOWED_MODULES=all to give full access.
# ============================================================================

# ── OpenAI (REQUIRED for AI chat features) ────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# ── MySQL Database (OPTIONAL — leave blank for demo mode) ─────────────────────
# Without these, InvenIQ runs in demo mode with sample data.
# All other features (UI, charts, exports, AI chat) work fully in demo mode.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=stocksense
MYSQL_PASSWORD=your_db_password
MYSQL_DB=stocksense_inventory

# ── Authentication ────────────────────────────────────────────────────────────
# IMPORTANT: Change JWT_SECRET_KEY to a unique random string before go-live.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-32-CHAR-STRING-BEFORE-GOLIVE
ACCESS_TOKEN_EXPIRE_HOURS=8

# ── Client account (what the client logs in with) ────────────────────────────
# AUTH_ROLE: use "client" to enforce module restrictions, "admin" for full access.
# AUTH_ALLOWED_MODULES: comma-separated module IDs the client can access.
#
# Modules available for restriction (use exact IDs):
#   overview, analytics, inventory, catalog, demand, deadstock, inward, warehouse,
#   procurement, pogrn, sales, customers, louvers, orders, freight, pos, quotes,
#   discounts, schemes, claims, finance, credit, projects, chatbot, settings, about
#
# Example — Quotation-focused client (recommended starter config):
#   quotes, customers, catalog, chatbot, settings, about
#
AUTH_USERNAME=client
AUTH_PASSWORD=your_secure_client_password
AUTH_DISPLAY_NAME=Client Name
AUTH_EMAIL=client@clientcompany.com
AUTH_ROLE=client
AUTH_ALLOWED_MODULES=quotes,customers,catalog,chatbot,settings,about

# ── Developer/owner backdoor (your private admin access) ─────────────────────
# This account always has full admin access regardless of AUTH_ROLE above.
# Leave OWNER_USERNAME blank to disable the backdoor account entirely.
# Use a strong unique password different from the client's password.
OWNER_USERNAME=devadmin
OWNER_PASSWORD=your_private_admin_password
OWNER_DISPLAY_NAME=Developer
OWNER_EMAIL=dev@yourcompany.com

# ── CORS — who can call the API ───────────────────────────────────────────────
# For single-machine install: http://localhost,http://127.0.0.1
# For LAN access: add your server's LAN IP, e.g. http://192.168.1.100
# For cloud/domain: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ── Email Notifications (OPTIONAL) ───────────────────────────────────────────
# Used for delivery delay alerts. Needs a Gmail App Password.
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password_here
NOTIFICATION_EMAIL=your_notification_email@gmail.com
