/frontend/build/
/frontend/dist/
# Generic Python build dir (never commit compiled Python dist)
build/

# ── Environment variables & Secrets — NEVER COMMIT ───────────────────────────
.env
.env.local
.env.*.local
*.env
# SSL / credentials — never commit
*.pem
*.key
*.crt
*.p12
*.pfx

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

