logs/
*.log
*.tmp
*.bak
*.old
# Test/scratch text files (e.g. test_wa.txt, tmp*.txt)
test_*.txt
tmp*.txt
*tmptest*

# ── Dev caches (auto-regenerated) ────────────────────────────────────────────
.cache/

# ── Claude Code local settings (machine-specific, not tracked) ───────────────
