# ── AI ─────────────────────────────────────────────────────────────────────────
# Required for AI chat, insights, demand forecasting, and WhatsApp scanner.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# ── Database (optional — leave blank for Demo Mode) ────────────────────────────
# Demo Mode works without MySQL — all 37 modules show realistic sample data.
# Set MYSQL_HOST to connect to a live database and see real business data.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=stocksense
MYSQL_PASSWORD=your_password_here
MYSQL_DB=stocksense_inventory

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, replace localhost with your actual domain (e.g. https://app.inveniq.in).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Authentication — JWT & default admin credentials ──────────────────────────
# IMPORTANT: Set JWT_SECRET_KEY to a strong random string before deploying.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=inveniq-dev-change-this-in-production-2026
ACCESS_TOKEN_EXPIRE_HOURS=8

# ── Primary login account ─────────────────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=inveniq@2024
AUTH_DISPLAY_NAME=Admin
AUTH_EMAIL=admin@inveniq.app
AUTH_ROLE=admin

# Comma-separated module IDs, or "all" for unrestricted access (admin always gets all).
# Available modules (37 total):
#   overview, analytics, inventory, catalog, demand, deadstock, inward, damage, warehouse
#   procurement, pogrn, landingcost, pr, qc, invoicematch
#   sales, customers, louvers, salesreturn, orders, freight, pos, claims, discounts, schemes
#   finance, credit, invoices, reports
#   projects, quotes, designquote
#   tally, distributor
#   chatbot, about, settings
# Role examples:
#   Sales:   sales,customers,louvers,orders,quotes,pos,claims,discounts,schemes,chatbot,about,settings
#   Finance: finance,credit,invoices,reports,tally,customers,orders,chatbot,about,settings
#   CFO:     overview,analytics,finance,credit,invoices,reports,tally,sales,customers,chatbot,about,settings
AUTH_ALLOWED_MODULES=all

# ── Owner / developer backdoor (optional) ─────────────────────────────────────
# Retains full admin access on a client deployment where AUTH_ROLE restricts the main account.
# Leave both blank to disable (no backdoor account).
OWNER_USERNAME=
OWNER_PASSWORD=
OWNER_DISPLAY_NAME=Owner
OWNER_EMAIL=

# ── Email notifications (optional) ────────────────────────────────────────────
# Used for invoice email delivery and delivery delay alerts.
# Use a Gmail App Password (NOT your regular Gmail password).
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password_here
NOTIFICATION_EMAIL=your_notification_email@gmail.com
