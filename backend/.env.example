OPENAI_API_KEY=sk-...your-key-here...
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=stocksense
MYSQL_PASSWORD=your_password_here
MYSQL_DB=stocksense_inventory
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Authentication — JWT & default admin credentials ──────────────────────────
# IMPORTANT: Set JWT_SECRET_KEY to a strong random string before deploying to production.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=inveniq-dev-change-this-in-production-2026
ACCESS_TOKEN_EXPIRE_HOURS=8

# Client / default user — the primary login account
AUTH_USERNAME=admin
AUTH_PASSWORD=inveniq@2024
AUTH_DISPLAY_NAME=Admin
AUTH_EMAIL=admin@inveniq.app
AUTH_ROLE=admin
# Comma-separated module IDs this user can access, or "all" for unrestricted.
# Admin role always gets all modules regardless. For a restricted client user:
# Example: AUTH_ALLOWED_MODULES=quotes,customers,catalog,chatbot,settings,about
AUTH_ALLOWED_MODULES=all

# ── Owner / developer backdoor (optional) ─────────────────────────────────────
# Set OWNER_USERNAME + OWNER_PASSWORD to retain full admin access on a client
# deployment where AUTH_ROLE=client restricts the main account.
# Leave both blank to disable this backdoor entirely.
OWNER_USERNAME=
OWNER_PASSWORD=
OWNER_DISPLAY_NAME=Owner
OWNER_EMAIL=

# Email — delivery delay notifications
# Use a Gmail App Password (not your regular Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password_here
NOTIFICATION_EMAIL=your_notification_email@gmail.com
